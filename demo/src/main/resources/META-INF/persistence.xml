<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="algorithmPresentPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.main.entity.AlgorithmEntity</class>
        <class>com.example.main.entity.UserEntity</class>
        <class>com.example.main.entity.UserSessionEntity</class>
        <class>com.example.main.entity.UserNoteEntity</class>
        <class>com.example.main.entity.UserReportEntity</class>
        <class>com.example.main.entity.UserModuleNoteEntity</class>
        <properties>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
