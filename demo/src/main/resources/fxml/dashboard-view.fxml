<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.main.controller.DashboardController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
            <padding>
                <Insets bottom="10" left="16" right="20" top="10" />
            </padding>

            <Button onAction="#toggleSidebar" styleClass="menu-btn" text="☰" />

            <Label styleClass="dashboard-title" text="Algorithm Visualizer" />

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="userLabel" styleClass="user-label" text="" />

            <Button onAction="#openReports" styleClass="top-report-btn" text="Reports" />

            <Button onAction="#handleLogout" styleClass="top-logout-btn" text="Đăng xuất" />
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox fx:id="sidebar" prefHeight="0.0" prefWidth="273.0" spacing="4" styleClass="sidebar">
            <padding>
                <Insets bottom="16" left="12" right="12" top="16" />
            </padding>

            <!-- Sorting Section -->
            <Label styleClass="sidebar-section" text="ALGORITHMS" />

            <Button fx:id="btnSort" onAction="#openSortingVisualizer" styleClass="sidebar-btn" text="⚙  Sorting Visualizer" />

            <!-- Data Structures Section -->
            <Label styleClass="sidebar-section" text="DATA STRUCTURES" />

            <Button fx:id="btnArray" onAction="#openArray" styleClass="sidebar-btn" text="▦  Array" />

            <Button fx:id="btnLinkedList" onAction="#openLinkedList" styleClass="sidebar-btn" text="⬡  LinkedList" />

            <Button fx:id="btnStack" onAction="#openStack" styleClass="sidebar-btn" text="⏫  Stack" />

            <Button fx:id="btnQueue" onAction="#openQueue" styleClass="sidebar-btn" text="△  Queue" />

            <Button fx:id="btnBinaryTree" onAction="#openBinaryTree" styleClass="sidebar-btn" text="⌥  Binary Tree" />

            <!-- Admin Section (chỉ hiển thị cho ADMIN) -->
            <Label fx:id="adminSection" managed="false" visible="false" styleClass="sidebar-section" text="QUẢN TRỊ" />

            <Button fx:id="btnAccounts" managed="false" visible="false" onAction="#openAccountManagement" styleClass="sidebar-btn" text="👤  Quản lý tài khoản" />

            <Button fx:id="btnReports" managed="false" visible="false" onAction="#openReportManagement" styleClass="sidebar-btn" text="📋  Tất cả báo cáo" />

        </VBox>
    </left>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: #F8FAFC;" />
    </center>

</BorderPane>

