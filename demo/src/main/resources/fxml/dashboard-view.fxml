<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.main.ui.DashboardController">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="12"
              styleClass="top-bar">
            <padding>
                <Insets top="10" right="20" bottom="10" left="16"/>
            </padding>

            <Button text="☰"
                    onAction="#toggleSidebar"
                    styleClass="menu-btn"/>

            <Label text="Algorithm Visualizer"
                   styleClass="dashboard-title"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox fx:id="sidebar"
              spacing="4"
              prefWidth="240"
              styleClass="sidebar">
            <padding>
                <Insets top="16" right="12" bottom="16" left="12"/>
            </padding>

            <!-- Sorting Section -->
            <Label text="THUẬT TOÁN"
                   styleClass="sidebar-section"/>

            <Button text="⚙  Mô phỏng sắp xếp"
                    onAction="#openSortingVisualizer"
                    styleClass="sidebar-btn, sidebar-btn-active"/>

            <!-- Data Structures Section -->
            <Label text="CẤU TRÚC DỮ LIỆU"
                   styleClass="sidebar-section"/>

            <Button text="▦  Array"
                    onAction="#openArray"
                    styleClass="sidebar-btn"/>

            <Button text="⬡  LinkedList"
                    onAction="#openLinkedList"
                    styleClass="sidebar-btn"/>

            <Button text="⏫  Stack"
                    onAction="#openStack"
                    styleClass="sidebar-btn"/>

            <Button text="△  Heap"
                    onAction="#openHeap"
                    styleClass="sidebar-btn"/>

            <Button text="⌥  Binary Tree"
                    onAction="#openBinaryTree"
                    styleClass="sidebar-btn"/>

        </VBox>
    </left>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentPane"
                   style="-fx-background-color: #F8FAFC;"/>
    </center>

</BorderPane>