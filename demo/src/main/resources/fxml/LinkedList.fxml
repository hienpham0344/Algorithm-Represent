<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.main.controller.LinkedListController"
            stylesheets="@../styles/LinkedList.css"
            styleClass="linked-root">

    <!-- LEFT CONTROL PANEL -->
    <left>
        <VBox prefWidth="300" spacing="16" styleClass="left-panel">
            <padding>
                <Insets top="18" right="16" bottom="18" left="16"/>
            </padding>

            <Label text="ⓘ MODULE INFO" styleClass="section-title"/>
            <Label text="Linked List" styleClass="module-title"/>
            <Label text="Dynamic chain of nodes linked by pointers.&#10;O(1) head insert, O(N) traversal.&#10;No contiguous memory required."
                   wrapText="true"
                   styleClass="description"/>

            <Separator/>

            <Label text="⚙ OPERATIONS" styleClass="section-title"/>
            <Label text="Element Value" styleClass="small-label"/>

            <TextField fx:id="inputField"
                       promptText="e.g. 42"
                       styleClass="input-field"/>

            <Label text="Index Position" styleClass="small-label"/>

            <TextField fx:id="indexField"
                       promptText="e.g. 0, 1, 2..."
                       styleClass="input-field"/>

            <GridPane hgap="8" vgap="8">
                <Button text="← Add Head" onAction="#handleAddHead" styleClass="btn-add-head" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Button text="→ Add Tail" onAction="#handleAddTail" styleClass="btn-add-tail" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Button text="🗑 Delete Head" onAction="#handleDeleteHead" styleClass="btn-delete" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Button text="🗑 Delete Tail" onAction="#handleDeleteTail" styleClass="btn-delete" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button text="➕ Insert At Index" onAction="#handleInsertAtIndex" styleClass="btn-add-head" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Button text="✂ Delete At Index" onAction="#handleDeleteAtIndex" styleClass="btn-delete" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Button text="🔍 Search" onAction="#handleSearch" styleClass="btn-search" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Button text="↻ Reset" onAction="#handleReset" styleClass="btn-reset" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Button text="📝 Notes" onAction="#handleNotes" styleClass="btn-search" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Button text="📂 Import .txt" onAction="#handleImportTxt" styleClass="btn-add-tail" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>


            <Separator/>
            <VBox spacing="8" styleClass="status-card">

                <Label text="SIMULATION STATUS"
                       styleClass="status-title"/>

                <Label fx:id="statusLabel"
                       text="Ready. Choose a linked list operation."
                       wrapText="true"
                       styleClass="status-text"/>

            </VBox>
        </VBox>
    </left>

    <!-- VISUALIZATION CANVAS -->
    <center>
        <Pane fx:id="canvasPane"
              prefHeight="430"
              styleClass="canvas-pane"/>
    </center>

    <!-- BOTTOM PANEL -->
    <bottom>
        <HBox  styleClass="bottom-area" prefHeight="210">

            <!-- PSEUDO-CODE -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"  VBox.vgrow="ALWAYS" styleClass="bottom-card">
                <HBox  alignment="CENTER_LEFT">
                    <Label text="&lt;&gt; PSEUDO-CODE" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Java code" styleClass="tag-label"/>
                </HBox>

                <TextArea fx:id="pseudoCodeArea"
                          text="// Choose an operation to view pseudo-code."
                          editable="false"
                          styleClass="code-area"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- EXPLANATION -->
            <VBox spacing="8"
                  HBox.hgrow="ALWAYS"
                  VBox.vgrow="ALWAYS"
                  styleClass="bottom-card">

                <HBox alignment="CENTER_LEFT">
                    <Label text="? EXPLANATION" styleClass="section-title"/>
                </HBox>

                <TextArea fx:id="explanationArea"
                          text="Select an operation to see a step-by-step explanation."
                          editable="false"
                          styleClass="code-area"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <!-- ACTIVITY LOG -->
            <VBox spacing="8" HBox.hgrow="ALWAYS"  VBox.vgrow="ALWAYS" styleClass="bottom-card">
                <HBox  alignment="CENTER_LEFT">
                    <Label text="&gt; ACTIVITY LOG" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Clear" styleClass="clear-label"/>
                </HBox>

                <TextArea fx:id="logArea"
                          text="[SYSTEM] DSA Visualizer initialized. Ready."
                          editable="false"
                          styleClass="code-area"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </bottom>

</BorderPane>