<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.main.ui.LinkedListController"
            stylesheets="@../styles/LinkedList.css"
            styleClass="linked-root">

    <!-- LEFT CONTROL PANEL -->
    <left>
        <VBox prefWidth="260" spacing="16" styleClass="left-panel">
            <padding>
                <Insets top="18" right="16" bottom="18" left="16"/>
            </padding>

            <Label text="ⓘ MODULE INFO" styleClass="section-title"/>
            <Label text="Linked List" styleClass="module-title"/>
            <Label text="Dynamic chain of nodes linked by pointers.&#10;O(1) head insert, O(N) traversal.&#10;No contiguous memory required."
                   wrapText="true"
                   styleClass="description"/>

            <Separator/>

            <Label text="⚙ OPERATIONS" styleClass="section-title"/>
            <Label text="Element Value" styleClass="small-label"/>

            <TextField fx:id="inputField"
                       promptText="e.g. 42"
                       styleClass="input-field"/>

            <GridPane hgap="8" vgap="8">
                <Button text="← Add Head" onAction="#handleAddHead" styleClass="btn-add-head" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Button text="→ Add Tail" onAction="#handleAddTail" styleClass="btn-add-tail" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Button text="🗑 Delete Head" onAction="#handleDeleteHead" styleClass="btn-delete" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Button text="🗑 Delete Tail" onAction="#handleDeleteTail" styleClass="btn-delete" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Button text="🔍 Search" onAction="#handleSearch" styleClass="btn-search" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Button text="↻ Reset" onAction="#handleReset" styleClass="btn-reset" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <!-- SPEED CONTROL -->
                <VBox spacing="8" styleClass="speed-box">
                    <Label text="⏱ Speed:" styleClass="speed-label"/>

                    <Slider fx:id="speedSlider"
                            min="0.2"
                            max="3"
                            value="1"
                            majorTickUnit="1"
                            minorTickCount="4"
                            showTickMarks="true"
                            showTickLabels="true"
                            blockIncrement="0.2"
                            styleClass="speed-slider"/>
                </VBox>

            <Separator/>

            <Label text="〽 SIMULATION STATUS" styleClass="section-title"/>

            <TextArea fx:id="statusArea"
                      text="Ready to start simulation."
                      editable="false"
                      wrapText="true"
                      prefHeight="240"
                      styleClass="status-area"/>
        </VBox>
    </left>

    <!-- VISUALIZATION CANVAS -->
    <center>
        <Pane fx:id="canvasPane"
              prefHeight="430"
              styleClass="canvas-pane"/>
    </center>

    <!-- BOTTOM PANEL -->
    <bottom>
        <HBox spacing="12" styleClass="bottom-area" prefHeight="210">

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="◇ PSEUDO-CODE" styleClass="section-title"/>
                <TextArea fx:id="pseudoCodeArea"
                          text="// Select an operation to view pseudo-code."
                          editable="false"
                          styleClass="code-area"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="⌁ ACTIVITY LOG" styleClass="section-title"/>
                <TextArea fx:id="logArea"
                          text="[System]: DSA Visualizer initialized. Ready."
                          editable="false"
                          styleClass="code-area"
                          VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </bottom>

</BorderPane>