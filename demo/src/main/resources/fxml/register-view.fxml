<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.main.ui.RegisterController"
           stylesheets="@../styles/login.css"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="24" styleClass="login-container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Title -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="📝" styleClass="logo-icon"/>
            <Label text="Create Account" styleClass="app-title"/>
            <Label text="Join Algorithm Visualizer" styleClass="subtitle"/>
        </VBox>

        <!-- Register Form -->
        <VBox spacing="16" styleClass="form-container">
            
            <!-- Username -->
            <VBox spacing="6">
                <Label text="Username *" styleClass="input-label"/>
                <TextField fx:id="usernameField"
                           promptText="Choose a username"
                           styleClass="input-field"/>
            </VBox>

            <!-- Full Name -->
            <VBox spacing="6">
                <Label text="Full Name" styleClass="input-label"/>
                <TextField fx:id="fullNameField"
                           promptText="Enter your full name"
                           styleClass="input-field"/>
            </VBox>

            <!-- Email -->
            <VBox spacing="6">
                <Label text="Email" styleClass="input-label"/>
                <TextField fx:id="emailField"
                           promptText="Enter your email"
                           styleClass="input-field"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Password *" styleClass="input-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Choose a password (min 6 chars)"
                               styleClass="input-field"/>
            </VBox>

            <!-- Confirm Password -->
            <VBox spacing="6">
                <Label text="Confirm Password *" styleClass="input-label"/>
                <PasswordField fx:id="confirmPasswordField"
                               promptText="Re-enter your password"
                               styleClass="input-field"/>
            </VBox>

            <!-- Error/Success Message -->
            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"
                   styleClass="error-label"
                   managed="false"
                   visible="false"/>

            <!-- Buttons -->
            <VBox spacing="12">
                <Button text="Create Account"
                        onAction="#handleRegister"
                        styleClass="btn-primary"
                        defaultButton="true"
                        maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Already have an account?" styleClass="link-label"/>
                    <Hyperlink text="Sign In" onAction="#handleBackToLogin" styleClass="link"/>
                </HBox>
            </VBox>
        </VBox>

    </VBox>

</StackPane>
