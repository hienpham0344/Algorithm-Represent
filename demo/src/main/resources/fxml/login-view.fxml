<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.main.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" maxWidth="380" spacing="14" styleClass="login-card">
        <padding>
            <Insets bottom="32" left="36" right="36" top="32" />
        </padding>

        <Label styleClass="login-logo" text="⚙" />
        <Label styleClass="login-title" text="Algorithm Visualizer" />
        <Label styleClass="login-subtitle" text="Đăng nhập để tiếp tục" />

        <Label styleClass="field-label" text="Tên đăng nhập" />
        <TextField fx:id="usernameField" promptText="username" styleClass="login-input" />

        <Label styleClass="field-label" text="Mật khẩu" />
        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="login-input" />

        <Label fx:id="errorLabel" styleClass="error-label" managed="false" visible="false" text="" wrapText="true" />

        <Button fx:id="loginButton" onAction="#handleLogin" defaultButton="true"
                maxWidth="Infinity" styleClass="login-btn" text="Đăng nhập" />

        <Label styleClass="login-hint" text="Mặc định: admin/admin123 · user/user123" />
    </VBox>

</StackPane>
