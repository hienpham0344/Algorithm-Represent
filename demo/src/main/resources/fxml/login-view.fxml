<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.main.ui.LoginController"
           stylesheets="@../styles/login.css"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="24" styleClass="login-container">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Logo/Title -->
        <VBox alignment="CENTER" spacing="8">
            <Label text="🔐" styleClass="logo-icon"/>
            <Label text="Algorithm Visualizer" styleClass="app-title"/>
            <Label text="Sign in to continue" styleClass="subtitle"/>
        </VBox>

        <!-- Login Form -->
        <VBox spacing="16" styleClass="form-container">
            
            <!-- Username -->
            <VBox spacing="6">
                <Label text="Username" styleClass="input-label"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           styleClass="input-field"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6">
                <Label text="Password" styleClass="input-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               styleClass="input-field"/>
            </VBox>

            <!-- Error Message -->
            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   styleClass="error-label"
                   managed="false"
                   visible="false"/>

            <!-- Buttons -->
            <VBox spacing="12">
                <Button text="Sign In"
                        onAction="#handleLogin"
                        styleClass="btn-primary"
                        defaultButton="true"
                        maxWidth="Infinity"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Don't have an account?" styleClass="link-label"/>
                    <Hyperlink text="Sign Up" onAction="#handleShowRegister" styleClass="link"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Info Box -->
        <VBox spacing="4" styleClass="info-box">
            <Label text="ℹ Default Account" styleClass="info-title"/>
            <Label text="Username: admin" styleClass="info-text"/>
            <Label text="Password: admin123" styleClass="info-text"/>
        </VBox>

    </VBox>

</StackPane>
